# Incubator - ESP-IDF sdkconfig defaults

# C++ standard settings
CONFIG_COMPILER_CXX_STANDARD_17=y
CONFIG_COMPILER_CXX_EXCEPTIONS=n
CONFIG_COMPILER_CXX_RTTI=n

# Core settings
CONFIG_FREERTOS_HZ=1000

# Memory settings
CONFIG_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_MODE=0
CONFIG_SPIRAM_USE_MEMMAP=n
CONFIG_SPIRAM_TYPE_AUTO_DETECT=y
CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=y

# Network settings
CONFIG_LWIP_MAX_SOCKETS=12
CONFIG_LWIP_DHCP_ENABLE=y
CONFIG_LWIP_UDP=y
CONFIG_LWIP_SNTP_MAX_SERVERS=3

# BLE provisioning
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=y
CONFIG_BTDM_CTRL_MODE_BR_EDR_ONLY=n
CONFIG_BTDM_CTRL_MODE_BTDM=n
CONFIG_BTDM_CTRL_HCI_MODE_VHCI=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y

# Security settings
CONFIG_ESP_TLS_USING_MBEDTLS=y
CONFIG_ESP_TLS_CLIENT=y

# Logging settings
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_COLORS=n
